  collectionName: string;
  subtitle?: string;
  detectedDealType?: string;
  status: "not_started" | "processing" | "complete" | "partial" | "error";
  lastUpdated?: string;

  documentCount: number;
  parsedDocumentCount?: number;
  classifiedDocumentCount?: number;

  dealSummary?: {
    dealName?: string;
    dealType?: string;
    issuer?: string;
    parAmount?: string;
    closingDate?: string;
    projectName?: string;
    location?: string;
